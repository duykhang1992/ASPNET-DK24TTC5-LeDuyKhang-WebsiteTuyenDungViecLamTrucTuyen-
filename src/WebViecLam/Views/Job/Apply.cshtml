@model WebViecLam.Models.Application

@{
    ViewBag.Title = "Ứng tuyển công việc";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Ứng tuyển: @ViewBag.JobTitle</h4>
                    <small>Công ty: @ViewBag.CompanyName</small>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("Apply", "Job", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.JobId)

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="form-group mb-3">
                            @Html.LabelFor(model => model.ApplicantName, htmlAttributes: new { @class = "control-label font-weight-bold" })
                            @Html.EditorFor(model => model.ApplicantName, new { htmlAttributes = new { @class = "form-control", placeholder = "Nhập họ và tên của bạn" } })
                            @Html.ValidationMessageFor(model => model.ApplicantName, "", new { @class = "text-danger" })
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "control-label font-weight-bold" })
                                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", type = "email", placeholder = "name@example.com" } })
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                            </div>

                            <div class="col-md-6 form-group mb-3">
                                @Html.LabelFor(model => model.Phone, htmlAttributes: new { @class = "control-label font-weight-bold" })
                                @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control", placeholder = "09xx xxx xxx" } })
                                @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="control-label font-weight-bold">Tải lên CV (PDF, Word)</label>
                            <input type="file" name="cvFile" class="form-control-file border p-2 w-100 rounded" accept=".pdf,.doc,.docx" required />
                        </div>

                        <div class="form-group text-center">
                            <button type="submit" class="btn btn-success btn-lg px-5">Gửi CV Ứng Tuyển</button>
                            @Html.ActionLink("Hủy bỏ", "Details", new { id = Model.JobId }, new { @class = "btn btn-outline-secondary btn-lg ml-2" })
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>