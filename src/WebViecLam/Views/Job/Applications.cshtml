@model IEnumerable<WebViecLam.Models.Application>

@{
    ViewBag.Title = "Danh sách ứng viên";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Hồ sơ ứng tuyển: <span class="text-primary">@ViewBag.JobTitle</span></h2>
        @Html.ActionLink("← Quay lại danh sách việc", "Index", null, new { @class = "btn btn-outline-secondary" })
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Họ và Tên</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th>Ngày nộp</th>
                            <th class="text-center">Hồ sơ (CV)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold align-middle">@item.ApplicantName</td>
                                    <td class="align-middle">@item.Phone</td>
                                    <td class="align-middle">@item.Email</td>
                                    <td class="align-middle">@item.ApplyDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center align-middle">
                                        <a href="@item.CVPath" target="_blank" class="btn btn-sm btn-info text-white">
                                            <i class="fa fa-download"></i> Xem CV
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center p-4 text-muted">
                                    <i>Chưa có ứng viên nào nộp hồ sơ cho công việc này.</i>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>