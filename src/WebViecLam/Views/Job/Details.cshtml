@model WebViecLam.Models.Job

@{
    ViewBag.Title = "Chi tiết công việc";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="card-title text-primary font-weight-bold">@Model.Title</h2>
                    <h5 class="text-muted mb-4">@Model.CompanyName</h5>

                    <div class="p-3 mb-4 bg-light rounded">
                        <div class="row">
                            <div class="col-sm-6 mb-2">
                                <strong><i class="fa fa-money"></i> Mức lương:</strong>
                                <span class="text-success font-weight-bold">@Model.Salary</span>
                            </div>
                            <div class="col-sm-6 mb-2">
                                <strong><i class="fa fa-map-marker"></i> Địa điểm:</strong> @Model.Location
                            </div>
                            <div class="col-sm-6 mb-2">
                                <strong><i class="fa fa-calendar"></i> Hạn nộp:</strong> @Model.Deadline.ToString("dd/MM/yyyy")
                            </div>
                            <div class="col-sm-6 mb-2">
                                <strong><i class="fa fa-clock-o"></i> Ngày đăng:</strong> @Model.CreatedDate.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>

                    <h4 class="border-bottom pb-2">Mô tả công việc</h4>
                    <div class="card-text mt-3" style="line-height: 1.6;">
                        @Html.Raw(Model.Description)
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-success mb-3">
                <div class="card-body text-center">
                    <h5 class="card-title text-success">Bạn quan tâm công việc này?</h5>
                    <p class="card-text text-muted">Hãy gửi CV ngay để nhà tuyển dụng liên hệ với bạn.</p>

                    <a href="@Url.Action("Apply", "Job", new { jobId = Model.JobId })" class="btn btn-success btn-lg btn-block w-100">
                        Ứng tuyển ngay
                    </a>
                </div>
                <div class="mt-3">
                    <a href="@Url.Action("Applications", "Job", new { id = Model.JobId })" class="btn btn-outline-info btn-block w-100">
                        <i class="fa fa-users"></i> Xem danh sách ứng viên (@Model.Applications.Count)
                    </a>
                </div>
            </div>

            <div class="text-center mt-3">
                @Html.ActionLink("← Quay lại danh sách", "Index", null, new { @class = "btn btn-outline-secondary w-100" })
            </div>
        </div>
    </div>
</div>