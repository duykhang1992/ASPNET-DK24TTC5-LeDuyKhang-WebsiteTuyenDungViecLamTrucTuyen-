@model IEnumerable<WebViecLam.Models.Job>

@{
    ViewBag.Title = "Trang chủ";
}

<div class="bg-primary bg-opacity-10 py-5 rounded-4 mt-3 mb-5 text-center" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');">
    <div class="container py-5">
        <h1 class="display-5 fw-bold text-dark mb-3">Tìm Kiếm Công Việc Ước Mơ Của Bạn</h1>
        <p class="lead text-muted mb-5">Hàng ngàn cơ hội nghề nghiệp đang chờ đón bạn từ các công ty hàng đầu</p>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <form action="@Url.Action("Index", "Job")" method="get" class="bg-white p-3 rounded-pill shadow-sm d-flex">
                    <input type="text" name="searchString" class="form-control border-0 bg-transparent shadow-none" placeholder="Nhập tên công việc, kỹ năng..." required>
                    <div class="border-start mx-2"></div>
                    <input type="text" name="location" class="form-control border-0 bg-transparent shadow-none" placeholder="Địa điểm (VD: Hà Nội)">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">TÌM KIẾM</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row text-center mb-5">
    <div class="col-md-4 mb-3">
        <div class="p-4 border rounded-4 shadow-sm bg-white">
            <i class="fa fa-briefcase fa-3x text-primary mb-3"></i>
            <h2 class="fw-bold">1,200+</h2>
            <p class="text-muted mb-0">Việc làm đang tuyển</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="p-4 border rounded-4 shadow-sm bg-white">
            <i class="fa fa-building fa-3x text-success mb-3"></i>
            <h2 class="fw-bold">350+</h2>
            <p class="text-muted mb-0">Công ty hàng đầu</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="p-4 border rounded-4 shadow-sm bg-white">
            <i class="fa fa-users fa-3x text-info mb-3"></i>
            <h2 class="fw-bold">5,000+</h2>
            <p class="text-muted mb-0">Ứng viên tiềm năng</p>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h3 class="fw-bold mb-1">Việc Làm Mới Nhất</h3>
            <p class="text-muted">Những cơ hội hấp dẫn vừa được cập nhật</p>
        </div>
        <a href="@Url.Action("Index", "Job")" class="btn btn-outline-primary rounded-pill">Xem tất cả <i class="fa fa-arrow-right ms-1"></i></a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                var logoUrl = string.IsNullOrEmpty(item.LogoPath)
                              ? $"https://ui-avatars.com/api/?name={item.CompanyName}&background=random&color=fff&size=80&rounded=true"
                              : item.LogoPath;

                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0 job-card" style="border-radius: 15px; transition: 0.3s;">
                        <div class="card-body d-flex align-items-center">
                            <img src="@logoUrl" alt="@item.CompanyName" class="rounded-circle shadow-sm" width="70" height="70" style="object-fit: cover;">
                            <div class="ms-3 w-100">
                                <h5 class="card-title mb-1 fw-bold">
                                    <a href="@Url.Action("Details", "Job", new { id = item.JobId })" class="text-dark text-decoration-none">@item.Title</a>
                                </h5>
                                <div class="text-muted small mb-2"><i class="fa fa-building-o"></i> @item.CompanyName</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="fa fa-money"></i> @item.Salary</span>
                                        <span class="badge bg-info bg-opacity-10 text-info px-2 py-1"><i class="fa fa-map-marker"></i> @item.Location</span>
                                    </div>
                                    <small class="text-muted">@item.CreatedDate.ToString("dd/MM")</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-4">
                <p class="text-muted">Hiện chưa có bài đăng mới nào.</p>
            </div>
        }
    </div>
</div>

<style>
    .job-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        border: 1px solid #0d6efd !important;
    }

    .form-control:focus {
        box-shadow: none;
    }
</style>